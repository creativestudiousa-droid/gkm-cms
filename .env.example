# Database (Railway PostgreSQL)
DB_CLIENT=pg
DB_CONNECTION_STRING=postgresql://postgres:password@host:5432/railway

# Security
SECRET=your-random-secret-key-min-32-chars

# Admin User (created on first run)
ADMIN_EMAIL=admin@gkmalik.com
ADMIN_PASSWORD=GKMAdmin2025!

# Server
PORT=8055
PUBLIC_URL=https://your-directus-url.railway.app
HOST=0.0.0.0

# CORS
CORS_ENABLED=true
CORS_ORIGIN=https://gkmalik.netlify.app,https://gkmalik.com

# Storage (local uploads)
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads

# Disable telemetry
TELEMETRY=false
